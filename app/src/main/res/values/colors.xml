         SEMANTIC COLORS — Dark-friendly success / danger
         ==================================================================== -->
    <color name="success_container">#1B3A2A</color>
    <color name="success_icon">#4CAF50</color>
    <color name="danger_container">#3A1B1B</color>
    <color name="danger_icon">#F44336</color>
    <color name="danger_text">#F44336</color>

