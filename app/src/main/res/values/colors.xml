<?xml version="1.0" encoding="utf-8"?>
<!--
    colors.xml — Dark Premium Color Palette for the Smart Wardrobe App
    Unified dark dashboard theme matching the Analytics screen aesthetic.
    All surface/text colors target the dark navy palette (#0C101B base).
-->
<resources>

    <!-- ====================================================================
         PRIMARY — Deep Indigo (kept for buttons, links, accents)
         ==================================================================== -->
    <color name="primary">#3F51B5</color>
    <color name="on_primary">#FFFFFF</color>
    <color name="primary_container">#1A2050</color>
    <color name="on_primary_container">#C5CAF6</color>

    <!-- ====================================================================
         SECONDARY — Warm Rose
         ==================================================================== -->
    <color name="secondary">#E91E63</color>
    <color name="on_secondary">#FFFFFF</color>
    <color name="secondary_container">#3E001E</color>
    <color name="on_secondary_container">#FFD9E3</color>

    <!-- ====================================================================
         TERTIARY — Soft Gold
         ==================================================================== -->
    <color name="tertiary">#FFB900</color>
    <color name="on_tertiary">#FFFFFF</color>

    <!-- ====================================================================
         SURFACE COLORS — Dark Dashboard Palette
         ==================================================================== -->
    <color name="surface">#0C101B</color>
    <color name="on_surface">#FFFFFF</color>
    <color name="surface_variant">#1A2436</color>
    <color name="on_surface_variant">#8A9AA4</color>

