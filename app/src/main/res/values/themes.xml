<?xml version="1.0" encoding="utf-8"?>
<!--
    themes.xml — Material Design 3 Dark Theme Configuration
    Unified dark dashboard aesthetic across all screens.
-->
<resources>

    <!-- Base application theme — Material Design 3 Dark -->
    <style name="Theme.SmartWardrobe" parent="Theme.Material3.Dark.NoActionBar">

        <!-- Primary color — Deep Indigo -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/on_primary_container</item>

        <!-- Secondary color — Warm Rose -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/on_secondary_container</item>

        <!-- Tertiary color — Soft Gold -->
        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorOnTertiary">@color/on_tertiary</item>

        <!-- Surface colors — Dark dashboard palette -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>

        <!-- Surface container overrides — ensures all Material3 components
             (Cards, Dialogs, BottomSheets) use our dark card color -->
        <item name="colorSurfaceContainer">@color/surface_card</item>
        <item name="colorSurfaceContainerLow">@color/surface_card</item>
        <item name="colorSurfaceContainerHigh">@color/surface_card</item>
        <item name="colorSurfaceContainerHighest">#1C2638</item>

        <!-- Outline colors — subtle borders for dark theme -->
        <item name="colorOutline">@color/surface_card_stroke</item>
        <item name="colorOutlineVariant">@color/surface_card_stroke</item>

        <!-- Error color -->
        <item name="colorError">#F44336</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/surface</item>

        <!-- Status bar — dark to match app background -->
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Navigation bar — dark to match bottom nav -->
        <item name="android:navigationBarColor">@color/surface</item>

    </style>

</resources>
