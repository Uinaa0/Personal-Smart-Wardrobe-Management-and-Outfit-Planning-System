<?xml version="1.0" encoding="utf-8"?>
<!--
    dialog_select_clothing.xml — Bottom Sheet Dialog for Clothing Selection
    Contains a grid list of items for the selected category.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="?attr/colorSurfaceContainer">

    <!-- Header Drag Handle (visual M3 cue) -->
    <View
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="?attr/colorOutlineVariant"
        android:backgroundTint="?attr/colorOutlineVariant" />

    <!-- Dialog Header -->
    <TextView
        android:id="@+id/text_dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select Item"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/text_dialog_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pick an item from your wardrobe to load onto the stylist canvas."
        android:textSize="12sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginBottom="16dp" />

    <!-- Empty State for Dialog -->
    <TextView
        android:id="@+id/text_dialog_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="32dp"
        android:gravity="center"
        android:text="No items found for this category."
        android:textSize="14sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:visibility="gone" />

    <!-- Grid List of Selectable Items -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_select_clothing"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:scrollbars="vertical"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:spanCount="2" />

</LinearLayout>
