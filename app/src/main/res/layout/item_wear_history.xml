<?xml version="1.0" encoding="utf-8"?>
<!--
    item_wear_history.xml — Row layout for the Wear History list.
    Shows item thumbnail, title (category + fabric), and formatted date.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#1A2436"
    app:cardBackgroundColor="#121824">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Item Thumbnail -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1A2436">

            <ImageView
                android:id="@+id/image_history_item"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="@string/analytics_item_thumbnail" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Item Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <!-- Item Title (Category + Fabric) -->
            <TextView
                android:id="@+id/text_history_item_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Date Worn -->
            <TextView
                android:id="@+id/text_history_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#8A9AA4"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Color Indicator Dot -->
        <View
            android:id="@+id/view_history_color_dot"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:background="@drawable/shape_color_dot"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
