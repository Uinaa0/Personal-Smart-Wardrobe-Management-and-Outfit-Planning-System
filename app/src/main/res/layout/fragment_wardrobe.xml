<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_wardrobe.xml — Module 1: Digital Inventory Layout
    Contains the category filter chips, wardrobe grid, empty state, and FAB.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- Main content area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- App Bar / Header -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_wardrobe"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorSurface"
            app:title="@string/title_wardrobe"
            app:titleTextColor="?attr/colorOnSurface"
            app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge" />

        <!-- Category Filter Chips — Horizontally Scrollable Row
             Each chip represents a clothing category (T-Shirt, Jeans, etc.)
             Chips are dynamically generated in WardrobeFragment.java
             based on the categories actually present in the database. -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="@dimen/screen_padding"
            android:paddingEnd="@dimen/screen_padding"
            android:clipToPadding="false">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_categories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:paddingBottom="8dp"
                app:singleSelection="true"
                app:chipSpacingHorizontal="8dp" />

        </HorizontalScrollView>

        <!-- Wardrobe Grid — 2-column RecyclerView
             Displays MaterialCardView items with clothing images.
             Managed by GridLayoutManager in WardrobeFragment.java -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_wardrobe"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="80dp"
            tools:listitem="@layout/item_wardrobe"
            tools:spanCount="2"
            tools:layoutManager="GridLayoutManager" />

        <!-- Empty State — Shown when wardrobe is empty
             Encourages the user to add their first clothing item. -->
        <LinearLayout
            android:id="@+id/layout_empty_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="@dimen/screen_padding"
            android:visibility="gone">

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/ic_wardrobe"
                android:alpha="0.4"
                android:contentDescription="@string/empty_wardrobe" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/empty_wardrobe_title"
                android:textSize="20sp"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/empty_wardrobe_message"
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:gravity="center" />

        </LinearLayout>

    </LinearLayout>

    <!-- Floating Action Button — Opens the Add Item form
         Positioned at the bottom-right using CoordinatorLayout gravity. -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_item"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/fab_margin"
        android:contentDescription="@string/add_item"
        android:src="@drawable/ic_add"
        app:tint="@android:color/white"
        app:backgroundTint="?attr/colorPrimary"
        app:fabSize="normal"
        app:elevation="6dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
